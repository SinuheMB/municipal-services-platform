# ── Django ──────────────────────────────────────────────
SECRET_KEY=genera-una-clave-nueva-con-get_random_secret_key
DEBUG=True

# ── Base de datos local (Docker) ───────────────────────
DB_NAME=municipal_services
DB_USER=municipal_user
DB_PASSWORD=municipal_pass
DB_HOST=localhost
DB_PORT=5433

# ── Producción (Railway) ───────────────────────────────
# En Railway estas se configuran como Variables del servicio,
# NO se ponen en este archivo en producción real.
RAILWAY_ENVIRONMENT=production
ALLOWED_HOSTS=tu-dominio.up.railway.app
DATABASE_URL=postgresql://usuario:password@host:puerto/db
ADMIN_PASSWORD=define-una-contraseña-segura-aqui

# ── Build (solo necesario en Railway) ──────────────────
MISE_PYTHON_GITHUB_ATTESTATIONS=false
